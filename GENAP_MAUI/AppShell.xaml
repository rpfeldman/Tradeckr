<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GENAP_MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GENAP_MAUI"
    xmlns:pages="clr-namespace:GENAP_MAUI.Pages.MainNavigationBarPages"
    Title="GENAP_MAUI">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent Route="{x:Static local:Routes.DefaultTransaction}"
                  ContentTemplate="{DataTemplate pages:RegistTransactionPage}" />
    <ShellContent Route="{x:Static local:Routes.TradingTransactions}"
                  ContentTemplate="{DataTemplate pages:RegistTradeTransactionPage}" />
    <ShellContent Route="{x:Static local:Routes.Dashboard}"
                  ContentTemplate="{DataTemplate pages:MainDashboardPage}" />
    <ShellContent Route="{x:Static local:Routes.Categories}"
                  ContentTemplate="{DataTemplate pages:TransactionCategoriesPage}" />
    <ShellContent Route="{x:Static local:Routes.Graphs}"
                  ContentTemplate="{DataTemplate pages:GraphsPage}" />

</Shell>
