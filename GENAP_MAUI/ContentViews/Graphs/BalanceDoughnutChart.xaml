<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             x:Class="GENAP_MAUI.ContentViews.Graphs.BalanceDoughnutChart.BalanceDoughnutChart"
             x:Name="Root">

    <VerticalStackLayout>
        <Label Text="Proporción Ingresos vs Gastos" FontSize="18" FontAttributes="Bold" Margin="10,0"/>

        <Grid HeightRequest="300">
            <Label 
                x:Name="BalanceLabel"
                Text="Balance:&#10;0.00$"
                HorizontalOptions="Center" 
                VerticalOptions="Center" 
                HorizontalTextAlignment="Center"
                FontSize="16" 
                FontAttributes="Bold"
                Margin="0,0,0,30"
                TextColor="White"
                TranslationY="-1"
                InputTransparent="True" />

            <lvc:PieChart 
                Series="{Binding DoughnutChart, Source={x:Reference Root}}" 
                LegendPosition="Bottom"
                BackgroundColor="Transparent" />

        </Grid>
    </VerticalStackLayout>

</ContentView>