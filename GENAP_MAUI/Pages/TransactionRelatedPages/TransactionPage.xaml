<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GENAP_MAUI.ViewModels"
             x:Class="GENAP_MAUI.Pages.TransactionRelatedPages.TransactionPage"
             x:DataType="vm:TransactionPageViewModel">

    <VerticalStackLayout Padding="5" Spacing="20" VerticalOptions="Center">
        <Label Text="{Binding Transaction.Value, StringFormat='{0:N2}$'}"></Label>
        <Label Text="{Binding Transaction.Category}"></Label>
        <Label Text="{Binding Transaction.Date}"></Label>
        <Label Text="{Binding Transaction.Depletion}"></Label>
    </VerticalStackLayout>
    
</ContentPage>