<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GENAP_MAUI.ViewModels"
             x:Class="GENAP_MAUI.Pages.MainNavigationBarPages.RegistTradeTransactionPage"
             x:DataType="vm:RegistTradeTransactionPageViewModel">
   
    <ScrollView>
        <VerticalStackLayout>
            <Label Text="instrucciones y reglas*"></Label>


            <HorizontalStackLayout Spacing="3">
                <Label Text="Valor del movimiento:"></Label>
                <Entry Text="{Binding Value}" Placeholder="$" Keyboard="Numeric"></Entry>
                <Label Text="$"></Label>
            </HorizontalStackLayout>

            <DatePicker
                Date="{Binding PickedDate}"
                Format="d/mmm/yyy"
            />

            <Label Text="{Binding Depletion}"></Label>
            <Button Command="{Binding ChangeDepletionCommand}" Text="Cambiar"></Button>

            <Button Command="{Binding RegistTransactionCommand}" Text="Registrar movimiento"></Button>

        </VerticalStackLayout>
    </ScrollView>
  
</ContentPage>