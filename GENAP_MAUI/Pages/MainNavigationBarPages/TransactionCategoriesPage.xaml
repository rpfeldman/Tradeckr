<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GENAP_MAUI.ViewModels"
             xmlns:ic="clr-namespace:GENAP_MAUI.InnerComponents"
             x:Class="GENAP_MAUI.Pages.MainNavigationBarPages.TransactionCategoriesPage"
             x:DataType="vm:TransactionCategoriesPageViewModel">
    
    <ScrollView>
        <VerticalStackLayout>

            <CollectionView ItemsSource="{Binding Categories}">
                <CollectionView.ItemTemplate>

                    <DataTemplate x:DataType="ic:CategoryDto">
                        
                        <HorizontalStackLayout>
                            <Entry Text="{Binding CategoryName}"></Entry>
                            <Button Text="Borrar" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCategoryCommand}" CommandParameter="{Binding .}"></Button>
                        </HorizontalStackLayout>
                        
                    </DataTemplate>
                    
                </CollectionView.ItemTemplate>
            </CollectionView>

            <HorizontalStackLayout>
                <Entry Text="{Binding NewCategory}"></Entry>

                <Picker
                    Title="Seleccionar color de la categoria"
                    ItemsSource="{Binding GlobalResources.ColorList}"
                    ItemDisplayBinding="{Binding Value.DisplayName}"
                    SelectedItem="{Binding PickedColor}"/>

                <Button Text="Agregar" Command="{Binding AddCategoryCommand}"></Button>
            </HorizontalStackLayout>

            <Button Text="Guardar" Command="{Binding SaveCommand}"></Button>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>