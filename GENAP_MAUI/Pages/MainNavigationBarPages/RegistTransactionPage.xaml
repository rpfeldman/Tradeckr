<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GENAP_MAUI.ViewModels"
             x:Class="GENAP_MAUI.Pages.MainNavigationBarPages.RegistTransactionPage"
             x:DataType="vm:RegistTransactionPageViewModel">

    <ScrollView>
        <VerticalStackLayout>
            <Label Text="instrucciones y reglas*"></Label>

            <Entry Placeholder="$" Keyboard="Numeric"></Entry>
 
            <Picker
            Title="Categoria..."
            ItemsSource="{Binding GR.GlobalCategories}"
                SelectedItem="{Binding Category}"/>

            <DatePicker
                Date="{Binding PickedDate}"
                Format="d/mmm/yyy"
                />

            <VerticalStackLayout>
                <Label Text="{Binding Depletion}"></Label>
                <Button Text="Cambiar" Command="{Binding ChangeDepletionCommand}"></Button>
            </VerticalStackLayout>
            
            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>