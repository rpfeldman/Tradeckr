<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GENAP_MAUI.ViewModels"
             xmlns:local="clr-namespace:GENAP_MAUI"
             x:Class="GENAP_MAUI.Pages.MainNavigationBarPages.MainDashboardPage"
             x:DataType="vm:MainDashboardPageViewModel">

    <ScrollView>
        <VerticalStackLayout>
            <Label Text="Temporal navigation center"></Label>
            <Button Text="Registrar transaccion" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:Routes.DefaultTransaction}"></Button>
            <Button Text="Registrar transaccion de trading" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:Routes.TradingTransactions}"></Button>
            <Button Text="Ir a la lista de categorias" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:Routes.Categories}"></Button>
            <Button Text="Ir a la seccion de graficos" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:Routes.Graphs}"></Button>
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>