<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GENAP_MAUI.ViewModels"
             xmlns:charts="clr-namespace:GENAP_MAUI.ContentViews.Graphs"
             xmlns:nav="clr-namespace:GENAP_MAUI.ContentViews.Navigation"
             xmlns:local="clr-namespace:GENAP_MAUI"
             x:Class="GENAP_MAUI.Pages.MainNavigationBarPages.GraphsPage"
             x:DataType="vm:GraphsPageViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}">

    <Grid RowDefinitions="Auto,*">

 
        <Border Grid.Row="0"
                Style="{StaticResource InputField}"
                Margin="20,16,20,8">
            <Picker Title="Seleccionar período de tiempo"
                    ItemsSource="{x:Static local:GlobalResources.TimePeriodsList}"
                    ItemDisplayBinding="{Binding Value}"
                    SelectedItem="{Binding PickedTimePeriod}" />
        </Border>

        <ScrollView Grid.Row="1" Padding="20,8,20,20">
            <VerticalStackLayout Spacing="0">
                
                <VerticalStackLayout Spacing="4">
                    <Label Text="Apartado de graficos" Style="{StaticResource SubHeadline}" />
                    <Label Style="{StaticResource Caption}"
                          HorizontalTextAlignment="Center"
                          Text="Para una mejor visualizacion se recomienda usar el celular en horizontal." />
                </VerticalStackLayout>  

                <Label Text="Balance general" Style="{StaticResource SectionHeader}" />

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <charts:BalanceDoughnutChart Expenses="{Binding Expenses}" Income="{Binding Income}" Title="Dona de balance"/>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <charts:BalanceLineChart Transactions="{Binding TransactionsLog}" Title="Evolucion del balance"/>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <charts:ProportionDoughnutChart Categories="{Binding Categories}" Transactions="{Binding TransactionsLog}" Title="Proporcion global"/>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Análisis de gastos" Style="{StaticResource SectionHeader}" />

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <charts:ProportionDoughnutChart Categories="{Binding Categories}" Transactions="{Binding ExpensesLog}" Title="Gastos por categoria"/>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <charts:BasicLineChart Transactions="{Binding ExpensesLog}" LineColor="{StaticResource ExpenseRed}" Title="Evolucion del gasto"/>
                    </VerticalStackLayout>
                </Border>
                
                <Label Text="Análisis de ingresos" Style="{StaticResource SectionHeader}" />

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <charts:ProportionDoughnutChart Categories="{Binding Categories}" Transactions="{Binding IncomeLog}" Title="Ingresos por categoria" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <charts:BasicLineChart Transactions="{Binding IncomeLog}" LineColor="{StaticResource IncomeGreen}" Title="Evolucion del ingreso"/>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Comparativas" Style="{StaticResource SectionHeader}" />

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <charts:DoubleComparisonLineChart Transactions1="{Binding IncomeLog}" Color1="{StaticResource IncomeGreen}"
                                                          Transactions2="{Binding ExpensesLog}" Color2="{StaticResource ExpenseRed}" 
                                                          Title="Gastos vs ingresos"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <nav:BottomNavigationBar Grid.Row="0" Grid.RowSpan="2" />
    </Grid>
    
</ContentPage>