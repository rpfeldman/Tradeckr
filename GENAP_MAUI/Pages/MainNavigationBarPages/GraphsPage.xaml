<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GENAP_MAUI.ViewModels"
             xmlns:charts="clr-namespace:GENAP_MAUI.ContentViews.Graphs"
             x:Class="GENAP_MAUI.Pages.MainNavigationBarPages.GraphsPage"
             x:DataType="vm:GraphsPageViewModel">

	<ScrollView>
		<VerticalStackLayout>
            <Picker
			Title="Seleccionar periodo de tiempo"
			ItemsSource="{Binding TimePeriodsList}"
			ItemDisplayBinding="{Binding Value}"
			SelectedItem="{Binding PickedTimePeriod}"/>

            <charts:BalanceDoughnutChart Expenses="{Binding Expenses}" Income="{Binding Income}"></charts:BalanceDoughnutChart>

            <VerticalStackLayout>
                <Label Text="Proporcion gastos"></Label>
                <charts:ProportionDoughnutChart Categories="{Binding Categories}" Transactions="{Binding ExpensesLog}"></charts:ProportionDoughnutChart>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Text="Proporcion ingresos"></Label>
                <charts:ProportionDoughnutChart Categories="{Binding Categories}" Transactions="{Binding IncomeLog}"></charts:ProportionDoughnutChart>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Text="Proporcion global"></Label>
                <charts:ProportionDoughnutChart Categories="{Binding Categories}" Transactions="{Binding TransactionsLog}"></charts:ProportionDoughnutChart>
            </VerticalStackLayout>

            <charts:BalanceLineChart Transactions="{Binding TransactionsLog}"></charts:BalanceLineChart>

            <VerticalStackLayout>
                <Label Text="Ingresos vs gastos"></Label>
                <charts:DoubleComparisonLineChart Transactions1="{Binding IncomeLog}" Color1="Green" Transactions2="{Binding ExpensesLog}" Color2="Red"></charts:DoubleComparisonLineChart>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Text="Evolucion ingresos"></Label>
                <charts:BasicLineChart Transactions="{Binding IncomeLog}" LineColor="Green"></charts:BasicLineChart>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Text="Evolucion gastos"></Label>
                <charts:BasicLineChart Transactions="{Binding ExpensesLog}" LineColor="Red"></charts:BasicLineChart>
            </VerticalStackLayout>


        </VerticalStackLayout>
    </ScrollView>
</ContentPage>